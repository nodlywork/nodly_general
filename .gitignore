# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Editor/OS
.vscode/
.idea/
.history/

# Next.js build/cache
.next/cache

# Logs
*.log

# Lockfiles (if you use one, keep it committed; otherwise ignore other lockfiles)
# Uncomment to ignore yarn or pnpm lockfiles if not used
# yarn.lock
# pnpm-lock.yaml

# Avoid syncing node_modules to cloud (OneDrive) — keep them local
# If you rely on OneDrive syncing, consider adding an exclusion in OneDrive settings instead
#/node_modules

.vercel
